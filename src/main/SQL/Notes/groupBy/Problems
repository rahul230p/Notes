Q6

Find days where DAU was greater than 100.


SELECT
    dt.calendar_dt,
    COUNT(DISTINCT f.user_id) AS dau
FROM fact_login_events f
JOIN dim_date dt
  ON f.date_id = dt.date_id
GROUP BY dt.calendar_dt
HAVING COUNT(DISTINCT f.user_id) > 100;




