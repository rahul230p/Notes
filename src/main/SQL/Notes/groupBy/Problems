Q10

Find users whose average daily steps are greater than 5000.

Grain - per user

select t.user_id, avg(t.total_step) as avg_steps from (
select dt.calendar_dt , f.user_id, sum(f.steps) as total_step
from fact_activity_events f
join dim_date dt on f.date_id = dt.date_id
group by
dt.calendar_dt , f.user_id
) t
group by t.userid
having avg(t.total_step) > 5000





