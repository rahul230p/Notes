select city_id , count(*) as delivered_orders
from orders
where order_status = 'Delivered'
group by city_id

select date(order_delivered_ts) as order_date,
sum(case when order_status = 'CREATED' then 1 else 0 end)
as orders_created_cnt,
sum(case when order_status = 'DELIVERED' then 1 else 0 end)
as orders_delivered_cnt
from orders
group by date(order_delivered_ts)

select d.dasher_name, count(*) as orders_delivered
from orders o join dashers d on o.dasher_id = d.dasher_id
and o.order_status = 'DELIVERED'
group by d.dasher_id, d.dasher_name

select dasher_id, date(order_delivered_ts) as order_date,
count(*) as orders_delivered
from orders
where order_status = 'DELIVERED'
group by dasher_id, date(order_delivered_ts)
having count(*) > 5


with orders_cnt as (
select city_id, date(order_delivered_ts) as order_date,
count(*) as orders_delivered
from orders
where order_status = 'DELIVERED')
select city_id, order_date,
orders_delivered - (lag(orders_delivered) over (partition by city order by order_date))
as day_over_day_change
from orders_cnt
order by city_id,order_date

with order_delivered_cnt as (
select dasher_id, date(order_delivered_ts) as order_date,
count(*) as orders_delivered
from orders
where order_status = 'DELIVERED'
group by dasher_id, date(order_delivered_ts)
)
select dasher_id,order_date, sum(orders_delivered) over (partition by
dasher_id order by order_date rows between 6 preceding and current row)
as rolling_sum
from order_delivered_cnt

with order_cnt as (
  select
    restaurant_id,
    sum(
      case
        when order_status = 'DELIVERED'
         and date(order_delivered_ts) >= current_date - interval 14 day
        then 1 else 0
      end
    ) as delivered_cnt,
    sum(
      case
        when order_status = 'CREATED'
         and date(order_created_ts) >= current_date - interval 14 day
        then 1 else 0
      end
    ) as created_cnt
  from orders
  group by restaurant_id
)
select restaurant_id
from order_cnt
where created_cnt > 0
  and delivered_cnt = 0;


with daily_deliveries as (
  select
    city_id,
    dasher_id,
    date(order_delivered_ts) as order_date,
    count(*) as deliveries_per_day
  from orders
  where order_status = 'DELIVERED'
  group by city_id, dasher_id, date(order_delivered_ts)
),
avg_deliveries as (
  select
    city_id,
    dasher_id,
    avg(deliveries_per_day) as avg_deliveries
  from daily_deliveries
  group by city_id, dasher_id
),
ranked as (
  select
    city_id,
    dasher_id,
    avg_deliveries,
    row_number() over (
      partition by city_id
      order by avg_deliveries desc
    ) as rnk
  from avg_deliveries
)
select
  city_id,
  dasher_id,
  avg_deliveries
from ranked
where rnk = 1;








