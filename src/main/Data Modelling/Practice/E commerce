Monthly Sales by Product

SELECT
    p.product_name,
    d.year,
    d.month,
    SUM(s.net_sales) AS monthly_sales
FROM fact_sales s
JOIN dim_product p
    ON s.product_id = p.product_id
JOIN dim_date d
    ON s.date_id = d.date_id
GROUP BY
    p.product_name,
    d.year,
    d.month;
