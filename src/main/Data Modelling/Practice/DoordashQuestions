Create or replace temp view daily_user_activity as
Select customer_id,
date(Watch_start_time_ts) as activity_date,
max(case when watch_duration_sec >= .5 * c.duration_minutes * 60 then 1 else 0 end )
As is_active
From Fact_Engagement e join class c on e.class_id = c.class_id
Group by e.customer_id, date(e.watch_start_ts)

Create or replace temp view daily_user_activity as
Select customer_id ,a ctivity_date from daily_user_activity
Where_is_active = 1

Create or replace temp view user_7_day_activity as
Select activity_date as metric_date,
Customer_id,
count(distinct activity_date) as active_days_last_7
From active_user_days d
Join active_user_days a
On d.customer_id = a.customer_id
And a.activity_date between date_sub(activity_dat, 6) and d.activity_date
Group by d.activity_date,a.customer_id

Avg
Select metric_date, avg(active_days_last_7) as activity_7_day_usage
From user_7_day_activity
Group by metric_date
Order by metric_date





